---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, slug: post.id },
  }));
}

type Props = { post: CollectionEntry<'blog'>; slug: string };

const { post, slug } = Astro.props;
const { Content } = await render(post);
const ogImage = `/og/${slug}.png`;
---

<BlogPost title={post.data.title} date={post.data.date} tags={post.data.tags} excerpt={post.data.excerpt} slug={slug} ogImage={ogImage}>
  <Content />
</BlogPost>